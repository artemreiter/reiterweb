---
const cases = [
  {
    industry: 'E-commerce',
    metric: '+147%',
    metricLabel: 'Conversion Rate',
    story: 'Rebuilt their entire measurement stack. Server-side tagging recovered 35% of lost conversions. Custom attribution revealed email was 3x more effective than paid social.',
    color: 'accent',
    barWidth: '82%',
  },
  {
    industry: 'SaaS',
    metric: '-62%',
    metricLabel: 'CAC Reduction',
    story: 'GA4 was tracking page views, nothing else. Full-funnel event tracking + lead scoring identified the 3 channels actually driving qualified signups.',
    color: 'violet',
    barWidth: '68%',
  },
  {
    industry: 'FinTech',
    metric: '3.8x',
    metricLabel: 'ROAS Improvement',
    story: 'Multi-touch attribution replaced last-click. Proved branded search was stealing credit from content marketing. Budget reallocation drove 3.8x ROAS.',
    color: 'amber',
    barWidth: '91%',
  },
];

const colorMap = {
  accent: { text: 'text-accent', bg: 'bg-accent', glow: 'glow-accent', border: 'border-accent/20' },
  violet: { text: 'text-violet', bg: 'bg-violet', glow: 'glow-violet', border: 'border-violet/20' },
  amber: { text: 'text-amber', bg: 'bg-amber', glow: 'glow-pink', border: 'border-amber/20' },
} as const;
---

<section id="cases" class="relative py-28 md:py-40">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-16 text-center reveal">
      <span class="font-mono text-[11px] text-accent uppercase tracking-[0.25em] mb-4 block">Results</span>
      <h2 class="text-[clamp(2rem,4vw,3rem)] font-display font-bold text-heading">
        The proof is in the <span class="text-gradient">data</span>
      </h2>
    </div>

    <!-- Cases -->
    <div class="grid md:grid-cols-3 gap-6">
      {cases.map((c, i) => {
        const colors = colorMap[c.color as keyof typeof colorMap];
        return (
          <div class={`reveal reveal-delay-${i + 1} group relative`}>
            <div class={`glass-strong rounded-2xl p-8 h-full flex flex-col transition-all duration-500 hover:${colors.glow}`}>
              <!-- Industry tag -->
              <div class="flex items-center gap-2 mb-8">
                <div class={`h-1.5 w-1.5 rounded-full ${colors.bg}`}></div>
                <span class={`text-[11px] font-mono uppercase tracking-[0.2em] ${colors.text}`}>
                  {c.industry}
                </span>
              </div>

              <!-- Metric -->
              <div class="mb-2">
                <span class={`font-mono text-[3.5rem] font-bold leading-none ${colors.text}`}>{c.metric}</span>
              </div>
              <span class="block text-[10px] font-mono text-muted uppercase tracking-widest mb-6">{c.metricLabel}</span>

              <!-- Progress bar -->
              <div class="h-1 rounded-full bg-border mb-6 overflow-hidden">
                <div
                  class={`h-full rounded-full ${colors.bg} transition-all duration-1000`}
                  style={`width: ${c.barWidth}`}
                ></div>
              </div>

              <!-- Story -->
              <p class="text-sm text-body leading-relaxed flex-1">
                {c.story}
              </p>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
