---
const issues = [
  ['GA4 revenue is higher than backend orders', 'Duplicate purchase, refunds ignored, or transaction_id missing'],
  ['Meta reports conversions the CRM cannot verify', 'Pixel/CAPI dedupe, attribution window or event quality problem'],
  ['Consent Mode is “installed” but not reliable', 'Defaults fire late, updates are inconsistent, or tags ignore state'],
  ['Looker Studio looks clean but numbers drift', 'Blended sources, weak join keys or mismatched metric definitions'],
  ['Paid media optimization gets weaker over time', 'Low-quality conversion payloads and missing enhanced signals'],
  ['Nobody knows which report is the source of truth', 'GA4, Shopify, CRM and ad platforms disagree without a reconciliation layer'],
];
---

<section id="proof" class="relative overflow-hidden border-y border-line bg-navy py-20 md:py-28 text-white">
  <div class="absolute inset-0 signal-grid opacity-[0.16]" aria-hidden="true"></div>
  <div class="mx-auto max-w-7xl px-5 lg:px-8 relative">
    <div class="mb-14 grid gap-8 md:grid-cols-[0.82fr_1fr] md:items-end">
      <div class="reveal">
        <p class="font-mono text-[11px] uppercase tracking-[0.16em] text-teal mb-4 font-semibold">Proof points</p>
        <h2 class="font-display text-[clamp(2.4rem,5vw,4.6rem)] font-extrabold leading-[0.98] tracking-[-0.045em] text-white">
          The audit starts where the numbers stop making sense.
        </h2>
      </div>
      <p class="reveal reveal-delay-1 max-w-2xl text-lg leading-8 text-white/72">
        Inspired by how mature measurement teams communicate: translate technical tracking defects into business impact, then hand off fixes that engineering can execute.
      </p>
    </div>

    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {issues.map((issue, i) => (
        <article class={`reveal reveal-delay-${(i % 4) + 1} rounded-[28px] border border-white/12 bg-white/[0.06] p-6 backdrop-blur-sm`}>
          <div class="mb-5 flex items-center justify-between gap-4">
            <span class="font-mono text-[11px] text-white/45">0{i + 1}</span>
            <span class:list={['rounded-full px-2.5 py-1 font-mono text-[10px] uppercase tracking-[0.1em]', i < 3 ? 'bg-orange/20 text-orange' : 'bg-teal/20 text-teal']}>{i < 3 ? 'High risk' : 'Medium risk'}</span>
          </div>
          <h3 class="mb-3 font-display text-2xl font-extrabold tracking-[-0.045em] text-white">{issue[0]}</h3>
          <p class="text-sm leading-6 text-white/66">{issue[1]}</p>
        </article>
      ))}
    </div>
  </div>
</section>
