---
const colorMap = {
  accent: 'text-success',
  blue: 'text-accent',
  amber: 'text-amber',
} as const;

const dotColor = {
  accent: 'bg-success',
  blue: 'bg-accent',
  amber: 'bg-amber',
} as const;

const barColor = {
  accent: '#10B981',
  blue: '#0066FF',
  amber: '#FF6B2C',
} as const;

type AccentKey = keyof typeof colorMap;

const cases = [
  {
    industry: 'E-commerce',
    metric: '+147%',
    metricLabel: 'Conversion Rate',
    story: 'Rebuilt their entire measurement stack. Server-side tagging recovered 35% of lost conversions. Custom attribution model revealed that email was 3x more effective than paid social.',
    color: 'accent',
  },
  {
    industry: 'SaaS',
    metric: '-62%',
    metricLabel: 'CAC Reduction',
    story: 'Their GA4 was tracking page views, nothing else. We implemented full-funnel event tracking, built a lead scoring model, and identified the 3 channels actually driving qualified signups.',
    color: 'blue',
  },
  {
    industry: 'FinTech',
    metric: '3.8x',
    metricLabel: 'ROAS Improvement',
    story: 'Multi-touch attribution replaced last-click. We proved that branded search was getting credit for conversions started by content marketing. Budget reallocation drove 3.8x ROAS.',
    color: 'amber',
  },
];
---

<section id="results" class="relative py-20 md:py-28 bg-surface-alt">
  <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Section header -->
    <div class="mb-16 text-center reveal">
      <div class="flex items-center justify-center gap-3 mb-6">
        <div class="h-px w-12 bg-accent"></div>
        <span class="font-mono text-xs text-accent uppercase tracking-[0.25em]">Results</span>
        <div class="h-px w-12 bg-accent"></div>
      </div>
      <h2 class="text-[clamp(2.5rem,5vw,3.5rem)] font-display font-bold text-heading leading-[1.05]">
        Numbers That <span class="text-gradient">Matter</span>
      </h2>
      <p class="mt-5 text-lg text-body max-w-xl mx-auto leading-relaxed">
        Real outcomes from real engagements. No vanity metrics.
      </p>
    </div>

    <!-- Case study cards -->
    <div class="grid md:grid-cols-3 gap-8">
      {cases.map((c, i) => (
        <div
          class={`reveal reveal-delay-${i + 1} card-elevated group p-8 relative overflow-hidden`}
        >
          {/* Left accent bar on hover */}
          <div
            class="absolute left-0 top-0 w-1 h-0 group-hover:h-full transition-all duration-500 rounded-l-lg"
            style={`background-color: ${barColor[c.color as AccentKey]}`}
          ></div>

          {/* Industry tag */}
          <div class="flex items-center gap-2 mb-8">
            <div class={`h-1.5 w-1.5 rounded-full ${dotColor[c.color as AccentKey]}`}></div>
            <span class={`text-[11px] font-mono uppercase tracking-[0.2em] ${colorMap[c.color as AccentKey]}`}>
              {c.industry}
            </span>
          </div>

          {/* Big metric */}
          <div class="mb-6">
            <span class={`font-mono text-[3.5rem] font-bold leading-none ${colorMap[c.color as AccentKey]}`}>{c.metric}</span>
            <span class="block text-xs font-mono text-muted uppercase tracking-[0.15em] mt-3">{c.metricLabel}</span>
          </div>

          {/* Divider */}
          <div class="section-divider mb-6"></div>

          {/* Story */}
          <p class="text-sm text-body leading-relaxed">
            {c.story}
          </p>

          {/* Sparkline decoration */}
          <div class="mt-8 h-10 opacity-20 group-hover:opacity-50 transition-opacity duration-500">
            <svg viewBox="0 0 200 30" class="w-full h-full" preserveAspectRatio="none">
              <defs>
                <linearGradient id={`grad-${c.color}`} x1="0" x2="1" y1="0" y2="0">
                  <stop offset="0%" stop-color={barColor[c.color as AccentKey]} stop-opacity="0" />
                  <stop offset="30%" stop-color={barColor[c.color as AccentKey]} stop-opacity="1" />
                  <stop offset="100%" stop-color={barColor[c.color as AccentKey]} stop-opacity="1" />
                </linearGradient>
              </defs>
              <path
                d={c.color === 'accent'
                  ? 'M0,25 C20,24 30,26 50,22 C70,18 90,20 110,14 C130,8 150,10 170,5 C185,2 195,3 200,2'
                  : c.color === 'blue'
                  ? 'M0,20 C25,22 40,24 60,18 C80,12 100,15 120,10 C140,5 160,8 180,3 C190,2 195,2 200,3'
                  : 'M0,28 C20,26 35,28 55,20 C75,14 95,16 115,10 C135,6 155,8 175,4 C190,2 195,2 200,2'}
                fill="none"
                stroke={`url(#grad-${c.color})`}
                stroke-width="2"
                stroke-linecap="round"
              />
            </svg>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
