---
const year = new Date().getFullYear();
---

<footer class="border-t border-border py-12">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8">
      <!-- Logo + location -->
      <div class="flex flex-col items-center md:items-start gap-2">
        <div class="flex items-center gap-2">
          <span class="h-2 w-2 rounded-full bg-accent"></span>
          <span class="font-display font-bold text-heading">reiterweb</span>
        </div>
        <span class="text-xs text-muted font-mono">Based in Europe</span>
      </div>

      <!-- Links -->
      <div class="flex items-center gap-6">
        <a href="#services" class="text-xs text-muted hover:text-accent transition-colors">Services</a>
        <a href="#results" class="text-xs text-muted hover:text-accent transition-colors">Results</a>
        <a href="#process" class="text-xs text-muted hover:text-accent transition-colors">Process</a>
        <a href="#about" class="text-xs text-muted hover:text-accent transition-colors">About</a>
        <a href="#contact" class="text-xs text-muted hover:text-accent transition-colors">Contact</a>
      </div>

      <!-- Social + legal -->
      <div class="flex flex-col items-center md:items-end gap-3">
        <div class="flex items-center gap-4">
          <!-- LinkedIn -->
          <a href="https://linkedin.com/in/artemreiter" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-muted hover:text-accent transition-colors">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <!-- Twitter/X -->
          <a href="https://x.com/artemreiter" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)" class="text-muted hover:text-accent transition-colors">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        </div>
        <div class="flex items-center gap-4 text-xs text-muted font-mono">
          <span>&copy; {year} Reiterweb</span>
          <span class="text-border">|</span>
          <a href="/privacy" class="hover:text-accent transition-colors">Privacy</a>
        </div>
      </div>
    </div>
  </div>
</footer>
