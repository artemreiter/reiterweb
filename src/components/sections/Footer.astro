---
const year = new Date().getFullYear();
---

<footer class="border-t border-border py-12">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Logo -->
      <div class="flex items-center gap-2">
        <span class="h-2 w-2 rounded-full bg-accent"></span>
        <span class="font-display font-bold text-heading">reiterweb</span>
      </div>

      <!-- Links -->
      <div class="flex items-center gap-6">
        <a href="#services" class="text-xs text-muted hover:text-accent transition-colors">Services</a>
        <a href="#results" class="text-xs text-muted hover:text-accent transition-colors">Results</a>
        <a href="#process" class="text-xs text-muted hover:text-accent transition-colors">Process</a>
        <a href="#about" class="text-xs text-muted hover:text-accent transition-colors">About</a>
        <a href="#contact" class="text-xs text-muted hover:text-accent transition-colors">Contact</a>
      </div>

      <!-- Copyright -->
      <div class="text-xs text-muted font-mono">
        &copy; {year} Reiterweb. Built with data and care.
      </div>
    </div>
  </div>
</footer>
