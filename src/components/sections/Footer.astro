---
const year = new Date().getFullYear();
---

<footer class="border-t border-border py-8">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Logo -->
      <div class="flex items-center gap-2">
        <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
        <span class="font-mono text-xs text-muted">reiterweb</span>
      </div>

      <!-- Links -->
      <div class="flex items-center gap-6">
        <a href="#services" class="text-xs text-muted hover:text-white transition-colors">Services</a>
        <a href="#cases" class="text-xs text-muted hover:text-white transition-colors">Cases</a>
        <a href="#process" class="text-xs text-muted hover:text-white transition-colors">Process</a>
        <a href="#about" class="text-xs text-muted hover:text-white transition-colors">About</a>
      </div>

      <!-- Right -->
      <div class="flex items-center gap-4 text-xs text-muted">
        <!-- LinkedIn -->
        <a href="https://linkedin.com/in/artemreiter" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="hover:text-white transition-colors">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <!-- X -->
        <a href="https://x.com/artemreiter" target="_blank" rel="noopener noreferrer" aria-label="X" class="hover:text-white transition-colors">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        <span class="text-border">·</span>
        <span>&copy; {year} Reiterweb</span>
        <span class="text-border">·</span>
        <span>Based in Europe</span>
      </div>
    </div>
  </div>
</footer>
