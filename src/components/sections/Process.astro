---
const steps = [
  { num: '01', title: 'Audit', desc: 'We find what\'s broken.', color: 'accent' },
  { num: '02', title: 'Architect', desc: 'We design the fix.', color: 'violet' },
  { num: '03', title: 'Implement', desc: 'We build and test.', color: 'blue' },
  { num: '04', title: 'Optimize', desc: 'We refine forever.', color: 'amber' },
];

const dotColors: Record<string, string> = {
  accent: 'bg-accent shadow-[0_0_12px_rgba(0,255,209,0.4)]',
  violet: 'bg-violet shadow-[0_0_12px_rgba(139,92,246,0.4)]',
  blue: 'bg-blue shadow-[0_0_12px_rgba(59,130,246,0.4)]',
  amber: 'bg-amber shadow-[0_0_12px_rgba(251,191,36,0.4)]',
};

const textColors: Record<string, string> = {
  accent: 'text-accent',
  violet: 'text-violet',
  blue: 'text-blue',
  amber: 'text-amber',
};
---

<section id="process" class="relative py-28 md:py-40">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-20 reveal">
      <span class="font-mono text-[11px] text-accent uppercase tracking-[0.25em] mb-4 block">Process</span>
      <h2 class="text-[clamp(2rem,4vw,3rem)] font-display font-bold text-heading">
        How it works
      </h2>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical line (desktop) -->
      <div class="hidden md:block absolute left-[39px] top-0 bottom-0 w-px bg-border"></div>

      <div class="space-y-16 md:space-y-20">
        {steps.map((step, i) => (
          <div class={`reveal reveal-delay-${i + 1} relative flex gap-8 md:gap-16 items-start`}>
            <!-- Dot on timeline -->
            <div class="hidden md:flex shrink-0 w-20 items-center justify-center relative z-10">
              <div class={`w-3 h-3 rounded-full ${dotColors[step.color]}`}></div>
            </div>

            <!-- Content -->
            <div class="flex-1">
              <div class="flex items-baseline gap-4 mb-3">
                <span class={`font-mono text-sm ${textColors[step.color]} opacity-60`}>{step.num}</span>
                <h3 class="text-2xl md:text-3xl font-display font-bold text-heading">
                  {step.title}
                </h3>
              </div>
              <p class="text-body text-lg">
                {step.desc}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
