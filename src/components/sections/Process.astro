---
const steps = [
  ['01', 'Map the system', 'Tools, tags, consent states, dataLayer events, server endpoints and dashboards are documented before recommendations begin.'],
  ['02', 'Test real behavior', 'Browser sessions, payloads, consent choices, checkout paths and report queries are checked directly.'],
  ['03', 'Rank by impact', 'Each issue is tied to revenue distortion, signal loss, compliance risk, implementation effort and owner.'],
  ['04', 'Retest the fixes', 'Critical fixes are validated after implementation so the team knows the problem actually changed.'],
];
---

<section id="process" class="relative py-20 md:py-28 bg-white/64">
  <div class="mx-auto max-w-7xl px-5 lg:px-8">
    <div class="mb-14 max-w-3xl reveal">
      <p class="kicker mb-4">Process</p>
      <h2 class="font-display text-[clamp(2.4rem,5vw,4.6rem)] font-extrabold leading-[0.98] text-navy">
        A consulting process that feels like engineering, not guesswork.
      </h2>
    </div>

    <div class="relative grid gap-5 md:grid-cols-4">
      {steps.map((step, i) => (
        <article class={`reveal reveal-delay-${(i % 4) + 1} soft-panel p-6 md:p-7`}>
          <span class="mb-12 inline-flex rounded-full bg-blue-soft px-3 py-1.5 font-mono text-[11px] font-semibold text-blue">{step[0]}</span>
          <h3 class="mb-4 font-display text-2xl font-extrabold tracking-[-0.045em] text-navy">{step[1]}</h3>
          <p class="text-sm leading-6 text-body">{step[2]}</p>
        </article>
      ))}
    </div>
  </div>
</section>
