---
const services = [
  {
    title: 'Tracking audit',
    body: 'GA4, GTM, dataLayer, ecommerce events, UTMs and conversion tags checked against real browser behavior.',
    items: ['Duplicate / missing conversions', 'Event schema quality', 'Campaign parameter integrity'],
    color: 'blue',
  },
  {
    title: 'Consent & privacy QA',
    body: 'Consent Mode, CMP states, GPC/UOOM behavior and regional tag firing reviewed as part of measurement quality.',
    items: ['Default / update timing', 'Tag blocking by purpose', 'Consent-safe attribution'],
    color: 'teal',
  },
  {
    title: 'Server-side signals',
    body: 'Meta CAPI, enhanced conversions, sGTM and browser/server deduplication tested for payload quality and reliability.',
    items: ['event_id handoff', 'CAPI match quality', 'Server/browser reconciliation'],
    color: 'orange',
  },
  {
    title: 'Dashboard reconciliation',
    body: 'Looker Studio, BigQuery and source-of-truth checks so reports match the business instead of just looking finished.',
    items: ['Metric definitions', 'Join logic', 'Backend vs analytics checks'],
    color: 'purple',
  },
];

const colorClasses = {
  blue: 'bg-blue-soft text-blue',
  teal: 'bg-teal-soft text-teal',
  orange: 'bg-orange-soft text-orange',
  purple: 'bg-purple-soft text-purple',
};
---

<section id="scope" class="relative py-20 md:py-28">
  <div class="mx-auto max-w-7xl px-5 lg:px-8">
    <div class="mb-14 grid gap-8 md:grid-cols-[0.8fr_1fr] md:items-end">
      <div class="reveal">
        <p class="kicker mb-4">Services</p>
        <h2 class="font-display text-[clamp(2.4rem,5vw,4.6rem)] font-extrabold leading-[0.98] text-navy">
          Measurement consulting without the theatre.
        </h2>
      </div>
      <p class="reveal reveal-delay-1 max-w-2xl text-lg leading-8 text-body">
        The pattern across strong analytics consultancies is clear: sell trust, clarity and implementation — not abstract “insights”. This is the Reiterweb version: practical audits with evidence and fixes.
      </p>
    </div>

    <div class="grid gap-5 md:grid-cols-2">
      {services.map((service, i) => (
        <article class={`reveal reveal-delay-${(i % 4) + 1} card p-6 md:p-8`}>
          <div class="mb-8 flex items-start justify-between gap-5">
            <span class={`rounded-full px-3 py-1.5 font-mono text-[10px] font-semibold uppercase tracking-[0.12em] ${colorClasses[service.color]}`}>0{i + 1}</span>
            <span class="h-px flex-1 bg-line mt-3"></span>
          </div>
          <h3 class="mb-4 font-display text-3xl font-extrabold tracking-[-0.05em] text-navy">{service.title}</h3>
          <p class="mb-7 leading-7 text-body">{service.body}</p>
          <div class="grid gap-2">
            {service.items.map((item) => (
              <div class="flex items-center gap-3 rounded-2xl bg-soft px-4 py-3 text-sm text-body">
                <span class="h-1.5 w-1.5 rounded-full bg-blue"></span>
                {item}
              </div>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
