---
const services = [
  {
    title: 'Analytics Architecture',
    description: 'GA4 & GTM setup, server-side tagging, data layer design. We build the foundation that makes everything else possible.',
    tools: ['GA4', 'GTM', 'BigQuery', 'Server-side Tagging'],
    metric: '99.7%',
    metricLabel: 'Data Accuracy',
    accentColor: 'accent',
  },
  {
    title: 'Attribution & Measurement',
    description: 'Multi-touch attribution, conversion modeling, incrementality testing. Know exactly what drives your revenue.',
    tools: ['Attribution Models', 'Conversion API', 'A/B Testing', 'MMM'],
    metric: '3.2x',
    metricLabel: 'ROAS Improvement',
    accentColor: 'blue',
  },
  {
    title: 'Dashboards & Insights',
    description: 'Custom Looker Studio & Power BI dashboards. Automated reporting that turns data into decisions, not just charts.',
    tools: ['Looker Studio', 'Power BI', 'Automated Reports', 'AI Insights'],
    metric: '40hrs',
    metricLabel: 'Saved / Month',
    accentColor: 'amber',
  },
];

const metricColorMap = {
  accent: 'text-accent',
  blue: 'text-blue',
  amber: 'text-amber',
};
---

<section id="services" class="relative py-20 md:py-28">
  <!-- Glow orb -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[1000px] h-[600px] glow-orb-green pointer-events-none opacity-50"></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Section header -->
    <div class="mb-20 reveal">
      <div class="flex items-center gap-3 mb-6">
        <div class="h-px w-12 bg-accent"></div>
        <span class="font-mono text-xs text-accent uppercase tracking-[0.25em]">Services</span>
      </div>
      <h2 class="text-[clamp(2.5rem,5vw,4rem)] font-display font-bold text-heading leading-[1.05]">
        What We Do
      </h2>
      <p class="mt-5 text-lg text-body/80 max-w-xl leading-relaxed">
        End-to-end web analytics — from raw tracking implementation to actionable business insights.
      </p>
    </div>

    <!-- Cards grid -->
    <div class="grid md:grid-cols-3 gap-8">
      {services.map((service, i) => (
        <div class={`reveal reveal-delay-${i + 1} rotating-border group p-8 transition-all duration-500`}>
          <!-- Inner content -->
          <div class="relative z-10">
            <!-- Metric badge -->
            <div class="mb-8">
              <span class={`font-mono text-4xl font-bold ${metricColorMap[service.accentColor as keyof typeof metricColorMap]}`}>{service.metric}</span>
              <span class="block text-[11px] font-mono text-muted uppercase tracking-[0.15em] mt-2">{service.metricLabel}</span>
            </div>

            <!-- Title -->
            <h3 class="text-xl font-display font-bold text-heading mb-4 group-hover:text-accent transition-colors duration-300">
              {service.title}
            </h3>

            <!-- Description -->
            <p class="text-body/80 text-sm leading-relaxed mb-8">
              {service.description}
            </p>

            <!-- Tools -->
            <div class="flex flex-wrap gap-2">
              {service.tools.map((tool) => (
                <span class="text-xs font-mono text-muted/70 px-3 py-1.5 rounded-lg bg-void/50 border border-border/50 transition-colors duration-300 group-hover:border-accent/20">
                  {tool}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Tool logos marquee -->
    <div class="mt-24 overflow-hidden relative reveal">
      <div class="section-divider mb-10"></div>
      <div class="absolute left-0 top-0 bottom-0 w-32 bg-gradient-to-r from-void to-transparent z-10"></div>
      <div class="absolute right-0 top-0 bottom-0 w-32 bg-gradient-to-l from-void to-transparent z-10"></div>
      <div class="flex gap-16 items-center animate-marquee">
        {['Google Analytics 4', 'Google Tag Manager', 'BigQuery', 'Looker Studio', 'Power BI', 'Segment', 'Amplitude', 'Mixpanel', 'Snowflake', 'dbt', 'Google Analytics 4', 'Google Tag Manager', 'BigQuery', 'Looker Studio', 'Power BI', 'Segment', 'Amplitude', 'Mixpanel', 'Snowflake', 'dbt'].map((tool) => (
          <span class="whitespace-nowrap font-mono text-sm text-muted/30 hover:text-accent/60 transition-colors duration-500 shrink-0 cursor-default">
            {tool}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .animate-marquee {
    animation: marquee 35s linear infinite;
  }
</style>
