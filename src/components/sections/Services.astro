---

---

<section id="services" class="relative py-28 md:py-40">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-16 reveal">
      <span class="font-mono text-[11px] text-accent uppercase tracking-[0.25em] mb-4 block">Services</span>
      <h2 class="text-[clamp(2rem,4vw,3rem)] font-display font-bold text-heading">
        What we build
      </h2>
    </div>

    <!-- Bento grid -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
      <!-- Large: Analytics Architecture -->
      <div class="md:col-span-2 md:row-span-2 gradient-border group reveal">
        <div class="p-8 md:p-10 h-full flex flex-col justify-between bg-surface rounded-2xl">
          <div>
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 rounded-xl bg-accent-dim flex items-center justify-center">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-accent">
                  <path d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5z" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <span class="font-mono text-[10px] text-muted uppercase tracking-widest">Core Service</span>
            </div>
            <h3 class="text-xl md:text-2xl font-display font-bold text-heading mb-3 group-hover:text-accent transition-colors duration-300">
              Analytics Architecture
            </h3>
            <p class="text-body text-sm leading-relaxed mb-6">
              GA4 & GTM setup, server-side tagging, data layer design. We build the foundation that makes everything else possible.
            </p>
            <div class="flex flex-wrap gap-2">
              {['GA4', 'GTM', 'BigQuery', 'Server-side'].map((t) => (
                <span class="text-[11px] font-mono text-muted px-2.5 py-1 rounded-md bg-surface-alt border border-border">{t}</span>
              ))}
            </div>
          </div>
          <div class="mt-8 pt-6 border-t border-border">
            <span class="font-mono text-3xl font-bold text-accent">99.7%</span>
            <span class="block font-mono text-[10px] text-muted uppercase tracking-widest mt-1">Data Accuracy</span>
          </div>
        </div>
      </div>

      <!-- Large: Attribution -->
      <div class="md:col-span-2 md:row-span-2 gradient-border group reveal reveal-delay-1">
        <div class="p-8 md:p-10 h-full flex flex-col justify-between bg-surface rounded-2xl">
          <div>
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 rounded-xl bg-violet-dim flex items-center justify-center">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-violet">
                  <path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <span class="font-mono text-[10px] text-muted uppercase tracking-widest">Core Service</span>
            </div>
            <h3 class="text-xl md:text-2xl font-display font-bold text-heading mb-3 group-hover:text-violet transition-colors duration-300">
              Attribution & Measurement
            </h3>
            <p class="text-body text-sm leading-relaxed mb-6">
              Multi-touch attribution, conversion modeling, incrementality testing. Know exactly what drives your revenue.
            </p>
            <div class="flex flex-wrap gap-2">
              {['Attribution Models', 'Conversion API', 'A/B Testing', 'MMM'].map((t) => (
                <span class="text-[11px] font-mono text-muted px-2.5 py-1 rounded-md bg-surface-alt border border-border">{t}</span>
              ))}
            </div>
          </div>
          <div class="mt-8 pt-6 border-t border-border">
            <span class="font-mono text-3xl font-bold text-violet">3.2x</span>
            <span class="block font-mono text-[10px] text-muted uppercase tracking-widest mt-1">ROAS Improvement</span>
          </div>
        </div>
      </div>

      <!-- Small: Dashboards -->
      <div class="md:col-span-2 gradient-border group reveal reveal-delay-2">
        <div class="p-6 md:p-8 bg-surface rounded-2xl">
          <div class="flex items-start justify-between">
            <div>
              <h3 class="text-lg font-display font-bold text-heading mb-2 group-hover:text-amber transition-colors duration-300">
                Dashboards & BI
              </h3>
              <p class="text-body text-sm leading-relaxed">
                Looker Studio, Power BI, automated reporting that drives decisions.
              </p>
            </div>
            <span class="font-mono text-2xl font-bold text-amber shrink-0 ml-4">40hrs</span>
          </div>
          <span class="block font-mono text-[10px] text-muted uppercase tracking-widest mt-3 text-right">Saved / Month</span>
        </div>
      </div>

      <!-- Small: Server-Side -->
      <div class="md:col-span-2 gradient-border group reveal reveal-delay-3">
        <div class="p-6 md:p-8 bg-surface rounded-2xl">
          <div class="flex items-start justify-between">
            <div>
              <h3 class="text-lg font-display font-bold text-heading mb-2 group-hover:text-blue transition-colors duration-300">
                Server-Side Tagging
              </h3>
              <p class="text-body text-sm leading-relaxed">
                First-party data collection, cookie-less tracking, privacy compliance.
              </p>
            </div>
            <span class="font-mono text-2xl font-bold text-blue shrink-0 ml-4">+35%</span>
          </div>
          <span class="block font-mono text-[10px] text-muted uppercase tracking-widest mt-3 text-right">Conversion Recovery</span>
        </div>
      </div>
    </div>

    <!-- Trust marquee -->
    <div class="mt-24 overflow-hidden relative reveal">
      <div class="gradient-line mb-10"></div>
      <div class="absolute left-0 top-0 bottom-0 w-32 bg-gradient-to-r from-void to-transparent z-10"></div>
      <div class="absolute right-0 top-0 bottom-0 w-32 bg-gradient-to-l from-void to-transparent z-10"></div>
      <div class="flex gap-16 items-center animate-marquee">
        {['Google Analytics 4', 'Google Tag Manager', 'BigQuery', 'Looker Studio', 'Power BI', 'Segment', 'Amplitude', 'Snowflake', 'dbt', 'Mixpanel', 'Google Analytics 4', 'Google Tag Manager', 'BigQuery', 'Looker Studio', 'Power BI', 'Segment', 'Amplitude', 'Snowflake', 'dbt', 'Mixpanel'].map((tool) => (
          <span class="whitespace-nowrap font-mono text-xs text-border-light hover:text-accent/50 transition-colors duration-500 shrink-0 cursor-default">
            {tool}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
