---
import { GlowButton } from '../ui/GlowButton';
import { ParticleNetwork } from '../canvas/ParticleNetwork';
---

<section id="hero" class="relative h-screen flex items-center justify-center overflow-hidden">
  <!-- Canvas background -->
  <div class="absolute inset-0 pointer-events-auto">
    <ParticleNetwork client:load />
  </div>

  <!-- Gradient overlay at bottom -->
  <div class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-void to-transparent pointer-events-none"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
    <!-- Overline -->
    <div class="mb-6 opacity-0 animate-[fadeUp_0.6s_ease-out_0.2s_forwards]">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-border bg-surface/50 backdrop-blur-sm">
        <span class="h-1.5 w-1.5 rounded-full bg-accent animate-pulse"></span>
        <span class="text-xs font-mono text-muted uppercase tracking-widest">Web Analytics Agency</span>
      </span>
    </div>

    <!-- Headline -->
    <h1 class="opacity-0 animate-[fadeUp_0.8s_ease-out_0.4s_forwards]">
      <span class="block text-[clamp(2.5rem,6vw,5.5rem)] font-display font-bold text-heading leading-[1.05] tracking-tight">
        Your Data Has a Story.
      </span>
      <span class="block text-[clamp(2.5rem,6vw,5.5rem)] font-display font-bold text-accent leading-[1.05] tracking-tight">
        We Read It.
      </span>
    </h1>

    <!-- Subtitle -->
    <p class="mt-6 text-lg md:text-xl text-body max-w-2xl mx-auto leading-relaxed opacity-0 animate-[fadeUp_0.8s_ease-out_0.7s_forwards]">
      Web analytics consulting for businesses that want to stop guessing and start knowing.
    </p>

    <!-- CTAs -->
    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4 opacity-0 animate-[fadeUp_0.8s_ease-out_1s_forwards]">
      <GlowButton href="#contact" variant="amber" client:load>
        Get a Free Audit
      </GlowButton>
      <GlowButton href="#results" variant="outline" client:load>
        See Our Results
      </GlowButton>
    </div>
  </div>

  <!-- Floating metrics -->
  <div class="absolute bottom-24 left-0 right-0 z-10 pointer-events-none opacity-0 animate-[fadeUp_1s_ease-out_1.4s_forwards]">
    <div class="max-w-5xl mx-auto px-6 flex justify-between">
      <div class="hidden md:block">
        <span class="font-mono text-2xl font-bold text-accent">147%</span>
        <span class="block text-xs text-muted mt-1 font-mono uppercase tracking-wider">Avg. Conversion Lift</span>
      </div>
      <div class="hidden md:block text-center">
        <span class="font-mono text-2xl font-bold text-blue">50+</span>
        <span class="block text-xs text-muted mt-1 font-mono uppercase tracking-wider">Clients Served</span>
      </div>
      <div class="hidden md:block text-right">
        <span class="font-mono text-2xl font-bold text-heading">8 yrs</span>
        <span class="block text-xs text-muted mt-1 font-mono uppercase tracking-wider">Experience</span>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 opacity-0 animate-[fadeUp_0.6s_ease-out_1.8s_forwards]">
    <span class="text-[10px] font-mono text-muted uppercase tracking-[0.2em]">Scroll</span>
    <div class="w-5 h-8 rounded-full border border-border flex items-start justify-center p-1.5">
      <div class="w-1 h-2 rounded-full bg-accent animate-bounce"></div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
