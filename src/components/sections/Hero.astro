---
const checkpoints = [
  ['01', 'Ad click', 'gclid / fbclid'],
  ['02', 'Consent', 'CMP + GPC'],
  ['03', 'Browser tag', 'GA4 / pixels'],
  ['04', 'Server event', 'CAPI / sGTM'],
  ['05', 'Revenue', 'CRM / checkout'],
  ['06', 'Report', 'GA4 / Looker'],
];
---

<section class="hero-v12 relative isolate overflow-hidden border-b border-line bg-[#fbf6ec]">
  <div class="absolute inset-0 -z-30 bg-[radial-gradient(circle_at_20%_14%,rgba(255,221,166,0.66),transparent_27rem),radial-gradient(circle_at_76%_18%,rgba(199,236,231,0.62),transparent_31rem),linear-gradient(180deg,#fbf6ec_0%,#fffdf8_58%,#f2f7f8_100%)]" aria-hidden="true"></div>
  <div class="noise absolute inset-0 -z-20 opacity-[0.055]" aria-hidden="true"></div>

  <div class="mx-auto max-w-7xl px-5 lg:px-8">
    <div class="relative flex min-h-[calc(100svh-73px)] flex-col justify-center py-10 lg:py-12">
      <div class="reveal mx-auto max-w-6xl text-center">
        <div class="mb-7 inline-flex items-center gap-3 rounded-full border border-navy/10 bg-white/58 px-4 py-2 shadow-[0_18px_60px_-48px_rgba(7,27,58,0.46)] backdrop-blur">
          <span class="h-2 w-2 rounded-full bg-orange shadow-[0_0_20px_rgba(249,115,61,0.76)]"></span>
          <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.18em] text-muted">GA4 · GTM · consent · CAPI · Looker</span>
        </div>

        <h1 class="hero-title mx-auto max-w-6xl font-display text-[clamp(3.25rem,8.2vw,8.6rem)] font-black leading-[0.84] tracking-[-0.09em] text-navy text-balance">
          Make conversions <span class="trackable-mark relative inline-block px-[0.03em]">trackable</span>.
        </h1>

        <p class="mx-auto mt-6 max-w-3xl text-xl leading-9 text-ink/76 md:text-2xl md:leading-10">
          I audit the path from paid click to reported revenue — and turn vague tracking doubt into evidence your dev, media, and analytics teams can act on.
        </p>

        <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
          <a href="mailto:artem@reiterweb.com?subject=Tracking%20audit%20request&body=Hi%20Artem%2C%0A%0AWebsite%3A%20%0AStack%3A%20GA4%20%2F%20GTM%20%2F%20CMP%20%2F%20CAPI%20%2F%20other%0AThe%20number%20we%20do%20not%20trust%3A%20%0A" class="inline-flex min-h-12 items-center justify-center rounded-full bg-navy px-7 py-4 text-base font-semibold text-white shadow-[0_24px_58px_-34px_rgba(7,27,58,0.82)] transition-colors hover:bg-blue">
            Book a tracking audit
          </a>
          <a href="#proof" class="inline-flex min-h-12 items-center justify-center rounded-full border border-navy/15 bg-white/64 px-7 py-4 text-base font-semibold text-navy backdrop-blur transition-colors hover:border-blue hover:text-blue">
            See audit evidence
          </a>
        </div>
      </div>

      <div class="reveal reveal-delay-2 relative mx-auto mt-8 w-full max-w-6xl lg:mt-10" aria-label="Tracking signal path from click to report">
        <div class="signal-map relative overflow-hidden rounded-[2rem] border border-navy/10 bg-white/50 p-4 shadow-[0_42px_130px_-92px_rgba(7,27,58,0.58)] backdrop-blur-xl md:p-5">
          <svg class="pointer-events-none absolute inset-0 h-full w-full" viewBox="0 0 1120 270" preserveAspectRatio="none" fill="none" aria-hidden="true">
            <path class="hero-flow flow-main" d="M38 150 C170 52 302 250 430 140 C560 28 666 246 796 134 C904 42 1010 120 1084 76" />
            <path class="hero-flow flow-soft" d="M36 190 C178 112 282 122 396 188 C522 260 650 212 762 166 C878 118 960 154 1088 214" />
            <path class="hero-flow flow-warn" d="M88 82 C246 118 330 88 438 62 C578 28 656 94 742 100 C870 110 960 42 1050 126" />
          </svg>

          <div class="relative grid gap-3 md:grid-cols-6">
            {checkpoints.map((point, index) => (
              <div class:list={['checkpoint group relative min-h-[132px] rounded-[1.35rem] border bg-[#fffaf1]/72 p-4 transition-transform duration-300 hover:-translate-y-1', index === 2 ? 'border-orange/35 shadow-[0_22px_58px_-48px_rgba(249,115,61,0.84)]' : 'border-navy/8']}>
                <div class="mb-6 flex items-center justify-between">
                  <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.12em] text-muted">{point[0]}</span>
                  <span class:list={['h-2.5 w-2.5 rounded-full', index === 2 ? 'bg-orange shadow-[0_0_22px_rgba(249,115,61,0.78)]' : 'bg-teal shadow-[0_0_18px_rgba(22,184,166,0.45)]']}></span>
                </div>
                <h2 class="font-display text-2xl font-extrabold leading-none tracking-[-0.06em] text-navy">{point[1]}</h2>
                <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.11em] text-muted">{point[2]}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <style>
    .hero-v12 .reveal { opacity: 1; transform: none; }
    .hero-v12 .text-balance { text-wrap: balance; }
    .hero-title { font-feature-settings: 'ss01' 1; }
    .trackable-mark::after {
      content: '';
      position: absolute;
      left: 0.04em;
      right: 0.02em;
      bottom: 0.03em;
      height: 0.14em;
      z-index: -1;
      border-radius: 999px;
      background: linear-gradient(90deg, rgba(249,115,61,.38), rgba(22,184,166,.34));
    }
    .noise {
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 160 160' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    }
    .signal-map::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: linear-gradient(rgba(7,27,58,.055) 1px, transparent 1px), linear-gradient(90deg, rgba(7,27,58,.055) 1px, transparent 1px);
      background-size: 56px 56px;
      mask-image: linear-gradient(180deg, rgba(0,0,0,.58), transparent 76%);
      pointer-events: none;
    }
    .hero-flow {
      stroke-width: 2.2;
      stroke-linecap: round;
      stroke-dasharray: 13 17;
      animation: heroTrace 10s linear infinite;
      opacity: .78;
      filter: drop-shadow(0 10px 28px rgba(7,27,58,.10));
    }
    .flow-main { stroke: rgba(37,99,235,.42); }
    .flow-soft { stroke: rgba(22,184,166,.46); animation-delay: -2.8s; }
    .flow-warn { stroke: rgba(249,115,61,.43); animation-delay: -5.4s; }
    @keyframes heroTrace { to { stroke-dashoffset: -170; } }
    @media (max-width: 767px) {
      .hero-title { line-height: .88; }
      .checkpoint { min-height: 112px; }
    }
    @media (prefers-reduced-motion: reduce) {
      .hero-flow { animation: none !important; }
    }
  </style>
</section>
