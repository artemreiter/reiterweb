---
import { HeroBackground } from '../canvas/HeroChart';
---

<section class="relative min-h-screen flex flex-col justify-center overflow-hidden">
  <!-- Animated particle background -->
  <div class="absolute inset-0">
    <HeroBackground client:load />
  </div>

  <!-- Gradient mesh overlay -->
  <div class="absolute inset-0 gradient-mesh pointer-events-none" aria-hidden="true"></div>

  <!-- Bottom fade -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-void to-transparent pointer-events-none"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-5xl mx-auto px-6 lg:px-8 pt-24 md:pt-32">
    <!-- Badge -->
    <div class="mb-10 reveal">
      <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-border bg-surface/50 backdrop-blur-sm">
        <span class="h-1.5 w-1.5 rounded-full bg-accent animate-pulse"></span>
        <span class="font-mono text-[11px] text-muted uppercase tracking-[0.2em]">Web Analytics Agency</span>
      </span>
    </div>

    <!-- Kinetic headline -->
    <h1 class="font-display font-bold text-[clamp(3rem,8vw,6rem)] leading-[1.05] tracking-tight mb-8">
      <span class="block reveal" style="transition-delay: 0.1s">
        Your <span class="text-accent">data</span>
      </span>
      <span class="block reveal" style="transition-delay: 0.3s">
        is <span class="text-pink">screaming.</span>
      </span>
      <span class="block reveal text-gradient" style="transition-delay: 0.5s">
        We translate.
      </span>
    </h1>

    <!-- Subtitle -->
    <p class="reveal text-lg md:text-xl text-body max-w-lg leading-relaxed mb-10" style="transition-delay: 0.7s">
      Analytics consulting that turns chaos into clarity.
    </p>

    <!-- CTA -->
    <div class="reveal" style="transition-delay: 0.9s">
      <a
        href="#cta"
        class="group relative inline-flex items-center gap-3 px-8 py-4 rounded-full font-mono text-sm font-bold overflow-hidden transition-all duration-500 hover:shadow-[0_0_30px_rgba(0,255,209,0.2)]"
      >
        <!-- Gradient border -->
        <span class="absolute inset-0 rounded-full p-px bg-gradient-to-r from-accent to-violet" aria-hidden="true">
          <span class="block w-full h-full rounded-full bg-void group-hover:bg-void/80 transition-colors duration-500"></span>
        </span>
        <span class="relative text-white">Book a Free Audit</span>
        <svg class="relative w-4 h-4 text-accent group-hover:translate-x-1 transition-transform duration-300" fill="none" viewBox="0 0 16 16">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <!-- Metrics bar -->
    <div class="reveal mt-16 md:mt-24 flex flex-wrap gap-8 md:gap-16" style="transition-delay: 1.1s">
      <div>
        <span class="font-mono text-2xl md:text-3xl font-bold text-accent">147%</span>
        <span class="block font-mono text-[10px] text-muted uppercase tracking-[0.2em] mt-1">avg lift</span>
      </div>
      <div class="h-10 w-px bg-border hidden md:block"></div>
      <div>
        <span class="font-mono text-2xl md:text-3xl font-bold text-white">50+</span>
        <span class="block font-mono text-[10px] text-muted uppercase tracking-[0.2em] mt-1">clients</span>
      </div>
      <div class="h-10 w-px bg-border hidden md:block"></div>
      <div>
        <span class="font-mono text-2xl md:text-3xl font-bold text-white">8 yrs</span>
        <span class="block font-mono text-[10px] text-muted uppercase tracking-[0.2em] mt-1">experience</span>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 reveal" style="transition-delay: 1.3s">
    <div class="w-px h-8 overflow-hidden">
      <div class="w-px h-8 bg-accent" style="animation: scrollPulse 2s ease-in-out infinite"></div>
    </div>
  </div>
</section>
