---
import { GlowButton } from '../ui/GlowButton';
import { HeroChart } from '../canvas/HeroChart';
---

<!-- Sticky wrapper: hero stays pinned while chart grows -->
<div class="relative" style="height: 200vh;">
  <section id="hero" class="sticky top-0 h-screen flex items-center justify-center overflow-hidden">
    <!-- Chart background (grows on scroll) -->
    <HeroChart client:load />

    <!-- Subtle dot grid -->
    <div class="absolute inset-0 dot-grid pointer-events-none opacity-50"></div>

    <!-- Soft radial glow behind chart area -->
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at 60% 70%, rgba(0, 102, 255, 0.04) 0%, transparent 60%);"></div>

    <!-- Gradient overlays for readability -->
    <div class="absolute bottom-0 left-0 right-0 h-28 bg-gradient-to-t from-void/60 to-transparent pointer-events-none z-[1]"></div>
    <div class="absolute top-0 left-0 right-0 h-24 bg-gradient-to-b from-void/30 to-transparent pointer-events-none z-[1]"></div>

    <!-- Content (above chart) -->
    <div class="relative z-10 max-w-5xl mx-auto px-6 text-center">
      <!-- Overline badge -->
      <div class="mb-8 opacity-0 animate-[fadeUp_0.6s_ease-out_0.2s_forwards]">
        <span class="inline-flex items-center gap-3 px-5 py-2 rounded-full bg-surface/80 backdrop-blur-sm border border-border shadow-sm">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-accent"></span>
          </span>
          <span class="text-xs font-mono text-muted uppercase tracking-[0.2em]">Web Analytics Agency</span>
        </span>
      </div>

      <!-- Headline -->
      <h1 class="opacity-0 animate-[fadeUp_0.8s_ease-out_0.4s_forwards]">
        <span class="block text-[clamp(2.8rem,6.5vw,5.5rem)] font-display font-bold text-heading leading-[0.95] tracking-[-0.03em]">
          Your Data Has
        </span>
        <span class="block text-[clamp(2.8rem,6.5vw,5.5rem)] font-display font-bold leading-[0.95] tracking-[-0.03em] mt-2">
          <span class="text-heading">a </span><span class="text-gradient">Story.</span>
        </span>
        <span class="block text-[clamp(1.5rem,3.5vw,2.5rem)] font-display font-semibold text-accent leading-[1.15] tracking-[-0.02em] mt-4">
          We Read It.
        </span>
      </h1>

      <!-- Subtitle -->
      <p class="mt-8 text-lg md:text-xl text-body max-w-2xl mx-auto leading-relaxed opacity-0 animate-[fadeUp_0.8s_ease-out_0.7s_forwards]">
        Web analytics consulting for businesses that want to<br class="hidden md:block" />
        <span class="text-heading font-medium">stop guessing</span> and <span class="text-heading font-medium">start knowing.</span>
      </p>

      <!-- CTAs -->
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4 opacity-0 animate-[fadeUp_0.8s_ease-out_1s_forwards]">
        <GlowButton href="#contact" variant="amber" className="text-base px-9 py-4" client:load>
          Get a Free Audit
          <svg width="18" height="18" viewBox="0 0 16 16" fill="none" class="ml-1">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </GlowButton>
        <a href="#results" class="text-sm text-muted hover:text-accent transition-colors duration-300 font-medium flex items-center gap-1.5 py-3">
          See Our Results
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
            <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <!-- Floating metrics -->
      <div class="mt-14 opacity-0 animate-[fadeUp_1s_ease-out_1.3s_forwards]">
        <div class="inline-flex items-center gap-8 md:gap-14 bg-surface border border-border shadow-[0_1px_3px_rgba(0,0,0,0.06),0_8px_24px_rgba(0,0,0,0.04)] rounded-2xl px-8 py-5">
          <div class="text-center">
            <span class="font-mono text-2xl md:text-3xl font-bold text-success">147%</span>
            <span class="block text-[11px] text-muted mt-1 font-mono uppercase tracking-[0.12em]">Avg. Conversion Lift</span>
          </div>
          <div class="w-px h-10 bg-border"></div>
          <div class="text-center">
            <span class="font-mono text-2xl md:text-3xl font-bold text-accent">50+</span>
            <span class="block text-[11px] text-muted mt-1 font-mono uppercase tracking-[0.12em]">Clients Served</span>
          </div>
          <div class="w-px h-10 bg-border hidden sm:block"></div>
          <div class="text-center hidden sm:block">
            <span class="font-mono text-2xl md:text-3xl font-bold text-heading">8 yrs</span>
            <span class="block text-[11px] text-muted mt-1 font-mono uppercase tracking-[0.12em]">Experience</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll hint -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2 opacity-0 animate-[fadeUp_0.6s_ease-out_1.8s_forwards]">
      <div class="w-5 h-9 rounded-full border border-border flex items-start justify-center p-1.5">
        <div class="w-1 h-2.5 rounded-full bg-accent animate-bounce"></div>
      </div>
    </div>
  </section>
</div>

<style>
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
