---

---

<nav class="sticky top-0 z-40 border-b border-line/80 bg-white/86 backdrop-blur-xl" id="main-nav">
  <div class="mx-auto max-w-7xl px-5 lg:px-8">
    <div class="flex h-18 items-center justify-between py-4">
      <a href="/" class="flex items-center gap-3" aria-label="Reiterweb home">
        <span class="relative flex h-9 w-9 items-center justify-center rounded-2xl bg-navy text-white shadow-[0_12px_35px_-22px_rgba(7,27,58,0.9)]">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
            <path d="M4 14.5c3.5 0 3.5-7 7-7s3.5 7 7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <circle cx="4" cy="14.5" r="2" fill="#16B8A6"/>
            <circle cx="11" cy="7.5" r="2" fill="#F9733D"/>
            <circle cx="18" cy="14.5" r="2" fill="#2563EB"/>
          </svg>
        </span>
        <span>
          <span class="block font-display text-lg font-extrabold tracking-[-0.05em] text-navy">reiterweb</span>
          <span class="hidden font-mono text-[10px] uppercase tracking-[0.14em] text-muted sm:block">analytics tracking audits</span>
        </span>
      </a>

      <div class="hidden items-center gap-7 md:flex">
        <a href="#scope" class="text-sm font-medium text-body hover:text-blue transition-colors">Services</a>
        <a href="#proof" class="text-sm font-medium text-body hover:text-blue transition-colors">Proof</a>
        <a href="#process" class="text-sm font-medium text-body hover:text-blue transition-colors">Process</a>
        <a href="#about" class="text-sm font-medium text-body hover:text-blue transition-colors">About</a>
        <a
          href="mailto:artem@reiterweb.com?subject=Tracking%20audit%20request"
          class="inline-flex items-center rounded-full bg-navy px-5 py-2.5 text-sm font-semibold text-white shadow-[0_18px_42px_-28px_rgba(7,27,58,0.9)] transition-colors hover:bg-blue"
        >
          Book an audit
        </a>
      </div>

      <button class="rounded-full border border-line bg-white p-2 md:hidden" id="nav-toggle" aria-label="Toggle menu">
        <span class="block h-px w-5 bg-navy transition-all" id="bar1"></span>
        <span class="mt-1.5 block h-px w-5 bg-navy transition-all" id="bar2"></span>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="pointer-events-none fixed inset-x-4 top-20 z-30 flex flex-col gap-1 rounded-3xl border border-line bg-white p-4 opacity-0 shadow-[0_24px_70px_-38px_rgba(7,27,58,0.45)] transition-opacity md:hidden">
    <a href="#scope" class="rounded-2xl px-4 py-3 text-navy">Services</a>
    <a href="#proof" class="rounded-2xl px-4 py-3 text-navy">Proof</a>
    <a href="#process" class="rounded-2xl px-4 py-3 text-navy">Process</a>
    <a href="#about" class="rounded-2xl px-4 py-3 text-navy">About</a>
    <a href="mailto:artem@reiterweb.com?subject=Tracking%20audit%20request" class="mt-2 rounded-full bg-navy px-4 py-3 text-center font-semibold text-white">Book an audit</a>
  </div>
</nav>

<script>
  const toggle = document.getElementById('nav-toggle')!;
  const menu = document.getElementById('mobile-menu')!;
  const bar1 = document.getElementById('bar1')!;
  const bar2 = document.getElementById('bar2')!;
  let open = false;

  toggle.addEventListener('click', () => {
    open = !open;
    menu.classList.toggle('opacity-0', !open);
    menu.classList.toggle('pointer-events-none', !open);
    bar1.style.transform = open ? 'rotate(45deg) translateY(5px)' : '';
    bar2.style.transform = open ? 'rotate(-45deg) translateY(-5px)' : '';
  });

  menu.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      open = false;
      menu.classList.add('opacity-0', 'pointer-events-none');
      bar1.style.transform = '';
      bar2.style.transform = '';
    });
  });
</script>
