---

---

<section id="cta" class="relative py-28 md:py-40 overflow-hidden">
  <!-- Gradient mesh background -->
  <div class="absolute inset-0 gradient-mesh opacity-50" aria-hidden="true"></div>

  <div class="relative max-w-3xl mx-auto px-6 lg:px-8 text-center">
    <div class="reveal">
      <h2 class="text-[clamp(2rem,5vw,3.5rem)] font-display font-bold text-heading leading-tight mb-6">
        Ready to hear what your<br />
        <span class="text-gradient">data is saying?</span>
      </h2>

      <p class="text-lg text-body mb-10">
        Free 30-min discovery call. No commitment.
      </p>

      <!-- Email form -->
      <form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto mb-6" action="#" method="POST">
        <input
          type="email"
          name="email"
          required
          aria-label="Your email"
          class="flex-1 bg-surface border border-border rounded-full px-6 py-3.5 text-white text-sm focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent/30 transition-all duration-300 placeholder:text-muted"
          placeholder="you@company.com"
        />
        <button
          type="submit"
          class="inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-full bg-accent text-void text-sm font-mono font-bold hover:bg-accent-hover transition-all duration-300 hover:shadow-[0_0_20px_rgba(0,255,209,0.3)] shrink-0"
        >
          Get a Free Audit
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </form>

      <p class="text-xs text-muted">
        Or email directly: <a href="mailto:artem@reiterweb.com" class="text-accent hover:underline">artem@reiterweb.com</a>
      </p>
    </div>
  </div>
</section>
