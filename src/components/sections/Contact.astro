---

---

<section id="contact" class="relative py-28 md:py-40 overflow-hidden">
  <div class="absolute inset-0 grid-bg pointer-events-none"></div>
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[1000px] h-[600px] glow-orb-green pointer-events-none opacity-40"></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Section header -->
    <div class="mb-20 text-center reveal">
      <div class="flex items-center justify-center gap-3 mb-6">
        <div class="h-px w-12 bg-accent"></div>
        <span class="font-mono text-xs text-accent uppercase tracking-[0.25em]">Contact</span>
        <div class="h-px w-12 bg-accent"></div>
      </div>
      <h2 class="text-[clamp(2.5rem,5vw,4rem)] font-display font-bold text-heading leading-[1.05]">
        Let's Talk <span class="text-gradient">Data</span>
      </h2>
      <p class="mt-5 text-lg text-body/80 max-w-xl mx-auto leading-relaxed">
        Ready to turn your data into decisions? Tell us about your challenge.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-12 max-w-5xl mx-auto">
      <!-- Left: info -->
      <div class="reveal">
        <h3 class="text-2xl font-display font-bold text-heading mb-8">
          What happens next?
        </h3>
        <div class="space-y-8">
          {[
            { num: '01', color: 'text-accent', title: 'Free 30-min discovery call', desc: 'We discuss your current setup and goals.' },
            { num: '02', color: 'text-blue', title: 'Quick audit report', desc: 'We review your analytics and share initial findings.' },
            { num: '03', color: 'text-amber', title: 'Custom proposal', desc: 'A tailored plan with clear deliverables and timeline.' },
          ].map((step) => (
            <div class="flex gap-5 group">
              <div class="shrink-0">
                <span class={`font-mono text-2xl font-bold ${step.color} opacity-40 group-hover:opacity-100 transition-opacity duration-300`}>
                  {step.num}
                </span>
              </div>
              <div>
                <p class="text-heading font-semibold mb-1">{step.title}</p>
                <p class="text-body/70 text-sm">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-12 pt-8 section-divider">
          <div class="pt-8">
            <p class="font-mono text-[10px] text-muted uppercase tracking-[0.25em] mb-3">Or reach out directly</p>
            <a href="mailto:artem@reiterweb.com" class="text-accent hover:text-accent-hover transition-colors font-medium text-lg">
              artem@reiterweb.com
            </a>
          </div>
        </div>
      </div>

      <!-- Right: form -->
      <div class="reveal reveal-delay-2">
        <form class="glass rounded-2xl p-8 space-y-6" action="#" method="POST">
          <div>
            <label class="block text-[10px] font-mono text-muted uppercase tracking-[0.25em] mb-2.5">Name</label>
            <input
              type="text"
              name="name"
              required
              class="w-full bg-void/50 border border-border/50 rounded-xl px-5 py-3.5 text-heading text-sm focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent/20 transition-all duration-300 placeholder:text-muted/40"
              placeholder="Your name"
            />
          </div>
          <div>
            <label class="block text-[10px] font-mono text-muted uppercase tracking-[0.25em] mb-2.5">Company</label>
            <input
              type="text"
              name="company"
              class="w-full bg-void/50 border border-border/50 rounded-xl px-5 py-3.5 text-heading text-sm focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent/20 transition-all duration-300 placeholder:text-muted/40"
              placeholder="Company name"
            />
          </div>
          <div>
            <label class="block text-[10px] font-mono text-muted uppercase tracking-[0.25em] mb-2.5">Email</label>
            <input
              type="email"
              name="email"
              required
              class="w-full bg-void/50 border border-border/50 rounded-xl px-5 py-3.5 text-heading text-sm focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent/20 transition-all duration-300 placeholder:text-muted/40"
              placeholder="you@company.com"
            />
          </div>
          <div>
            <label class="block text-[10px] font-mono text-muted uppercase tracking-[0.25em] mb-2.5">Your biggest analytics challenge</label>
            <textarea
              name="message"
              rows={4}
              class="w-full bg-void/50 border border-border/50 rounded-xl px-5 py-3.5 text-heading text-sm focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent/20 transition-all duration-300 placeholder:text-muted/40 resize-none"
              placeholder="Tell us what you're struggling with..."
            ></textarea>
          </div>
          <button
            type="submit"
            class="shimmer w-full inline-flex items-center justify-center gap-2 px-7 py-4 rounded-full bg-accent text-void text-sm font-display font-bold hover:bg-accent-hover transition-all duration-300 shadow-[0_0_40px_var(--color-accent-dim)] hover:shadow-[0_0_60px_var(--color-accent-dim)] hover:scale-[1.02] active:scale-[0.98]"
          >
            Send Message
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
