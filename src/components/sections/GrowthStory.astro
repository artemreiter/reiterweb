---
import { ScrollChart } from '../canvas/ScrollChart';
---

<section id="growth" class="relative py-28 md:py-40 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 grid-bg pointer-events-none opacity-50"></div>
  <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[1200px] h-[800px] glow-orb-green pointer-events-none opacity-30"></div>

  <div class="relative max-w-6xl mx-auto px-6 lg:px-8">
    <!-- Section header -->
    <div class="mb-16 text-center reveal">
      <div class="flex items-center justify-center gap-3 mb-6">
        <div class="h-px w-12 bg-accent"></div>
        <span class="font-mono text-xs text-accent uppercase tracking-[0.25em]">The Journey</span>
        <div class="h-px w-12 bg-accent"></div>
      </div>
      <h2 class="text-[clamp(2rem,4vw,3.5rem)] font-display font-bold text-heading leading-[1.05]">
        From <span class="text-[#EF4444]">Broken</span> to <span class="text-gradient">+147%</span>
      </h2>
      <p class="mt-5 text-lg text-body/80 max-w-2xl mx-auto leading-relaxed">
        Watch a typical client journey unfold. Each milestone represents a real improvement — scroll to see the data grow.
      </p>
    </div>

    <!-- Chart -->
    <div class="reveal">
      <div class="relative rounded-2xl border border-border/50 bg-surface/30 backdrop-blur-sm p-6 md:p-10">
        <!-- Chart header -->
        <div class="flex items-center justify-between mb-8">
          <div>
            <span class="font-mono text-[10px] text-muted uppercase tracking-[0.25em]">Conversion Rate Over Time</span>
          </div>
          <div class="flex items-center gap-4">
            <div class="flex items-center gap-2">
              <div class="h-0.5 w-4 bg-[#EF4444] rounded"></div>
              <span class="font-mono text-[9px] text-muted">Before</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="h-0.5 w-4 bg-accent rounded"></div>
              <span class="font-mono text-[9px] text-muted">After Reiterweb</span>
            </div>
          </div>
        </div>

        <!-- Scroll Chart component -->
        <ScrollChart client:visible />

        <!-- Bottom note -->
        <div class="mt-6 flex items-center justify-center gap-2">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-muted/50">
            <path d="M12 5v14M5 12l7 7 7-7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span class="font-mono text-[10px] text-muted/50 uppercase tracking-[0.2em]">Scroll to animate</span>
        </div>
      </div>
    </div>
  </div>
</section>
